# Desarrollo: usar /api para que Vite enrute a Strapi (ver vite.config.js). Producción: URL absoluta del backend.
# Debe incluir /api al final (ej. https://tu-app.up.railway.app/api). Solo el host sin /api rompe POST (405) y GET (404).
# VITE_API_URL=/api
VITE_API_URL=http://localhost:1337/api
# Mismo Client ID (Application ID) que MP_CLIENT_ID en el backend — para el botón "Conectar con Mercado Pago" (OAuth).
VITE_MP_CLIENT_ID=
# Si usás proxy /api y el callback OAuth debe apuntar al host real de Strapi (ej. Railway), URL completa del callback:
# VITE_MP_OAUTH_REDIRECT_URI=https://tu-backend.up.railway.app/api/auth/mercadopago/callback
# Opcional: origen de Strapi si VITE_API_URL es relativo (alternativa a VITE_MP_OAUTH_REDIRECT_URI)
# VITE_STRAPI_URL=http://localhost:1337/api
# Clave pública de Mercado Pago (Wallet Brick). En Next: NEXT_PUBLIC_MP_PUBLIC_KEY
VITE_MP_PUBLIC_KEY=
