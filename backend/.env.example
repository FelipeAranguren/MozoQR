HOST=0.0.0.0
PORT=1337
# URL pública del backend (para redirects de OAuth)
PUBLIC_URL=http://localhost:1337
# URL del frontend (para aceptar ?callback= tras login con Google). En prod: https://tu-app.vercel.app
FRONTEND_URL=http://localhost:5173
# Orígenes permitidos para CORS (separados por coma). Prod: incluir https://mozoqr.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://mozoqr.vercel.app

# URL del frontend para redirects de pago (Mercado Pago back_urls). En prod/staging NO usar localhost.
# Si no se define, se usa FRONTEND_URL o https://mozoqr.vercel.app en producción.
PAYMENT_STATUS_URL=https://mozoqr.vercel.app

# Upload de imágenes (Cloudinary). Obligatorio en producción para que las imágenes persistan entre despliegues.
# Sin estas variables, Strapi usa almacenamiento local (public/uploads/) y se pierde en cada redeploy.
# Crear cuenta en https://cloudinary.com y obtener credenciales en Dashboard.
# CLOUDINARY_NAME=tu_cloud_name
# CLOUDINARY_KEY=tu_api_key
# CLOUDINARY_SECRET=tu_api_secret

# Base de datos. En producción (Railway): definir solo DATABASE_URL (PostgreSQL). Local: no definir para usar SQLite.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Mercado Pago (credenciales en https://www.mercadopago.com.ar/developers). En Railway: Variables del servicio.
MP_ACCESS_TOKEN=
# OAuth (botón "Conectar con Mercado Pago"): credenciales de TU APP en developers (una sola por despliegue).
# No son el Access Token del restaurante: esas van en la colección metodos_pagos tras OAuth o pegadas a mano.
# Obligatorias en el SERVIDOR (Railway). Si faltan: mp_msg=server_misconfigured.
MP_CLIENT_ID=
MP_CLIENT_SECRET=
# Alias opcionales (mismo valor que arriba): MERCADOPAGO_CLIENT_ID / MERCADOPAGO_CLIENT_SECRET o MERCADO_PAGO_*
# Opcional: si no se define, se usa PUBLIC_URL + /api/auth/mercadopago/callback (debe coincidir con el Redirect URL en MP)
# MP_REDIRECT_URI=https://mozoqr-production.up.railway.app/api/auth/mercadopago/callback

# MODO PCT (checkout). En Railway: mismos nombres en Variables del servicio que ejecuta Strapi (el .env local no viaja al deploy).
# Sin MODO_BASE_URL / MODO_TOKEN_URL: NODE_ENV=production → api.modo.com.ar; si no → development.api.modo.com.ar (no usar sandbox.api.modo.com.ar — no resuelve DNS).
# OAuth: POST …/connections/oauth/token | PCP: …/connections/pcp/{bcra}/payment (sin /backend/v1 en el path).
# MODO_PCP_BCRA_ID=999
# MODO_BASE_URL=https://development.api.modo.com.ar/connections/pcp/999
# (Nunca pongas texto tipo <BCRA_PROD>: tiene que ser un número, ej. 999.)
# MODO_TOKEN_URL=https://development.api.modo.com.ar/connections/oauth/token
# MODO_CLIENT_ID=
# MODO_CLIENT_SECRET=
# API Gateway (403 "Missing Authentication Token"): clave que suele dar MODO aparte del client_id — mismo valor que x-api-key en Postman/colección.
# MODO_API_KEY=
# Si MODO responde 401: revisá ID/secret (sandbox vs prod) y que en Railway no haya espacios ni comillas extra. El cliente envía X-Client-Id / X-Client-Secret además del body.
# Opcional: JWT manual en lugar de OAuth
# MODO_BEARER_TOKEN=

# IA del dashboard dueño (plan Ultra). Único proveedor: Google Gemini (AI Studio, tier gratis).
# Modelos usados en orden: gemini-2.5-flash → gemini-3.5-flash → fallbacks lite.
# Clave gratis: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Super Admin (emails separados por coma, sin espacios extra)
# PLATFORM_ADMIN_EMAILS=marioealfonzo@gmail.com,otro@ejemplo.com

APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
