{
  "kind": "collectionType",
  "collectionName": "productos",
  "info": {
    "singularName": "producto",
    "pluralName": "productos",
    "displayName": "Producto"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "description": {
      "type": "blocks"
    },
    "restaurante": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::restaurante.restaurante",
      "inversedBy": "productos"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "item_pedidos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::item-pedido.item-pedido",
      "mappedBy": "product"
    },
    "slug": {
      "type": "string"
    },
    "available": {
      "type": "boolean",
      "default": true
    },
    "sku": {
      "type": "string"
    },
    "extras": {
      "type": "json"
    },
    "categoria": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::categoria.categoria",
      "inversedBy": "productos"
    },
    "stock_enabled": {
      "type": "boolean",
      "default": false
    },
    "stock_quantity": {
      "type": "decimal",
      "default": 0
    },
    "stock_unit": {
      "type": "enumeration",
      "enum": ["unidad", "kg", "litro", "porcion"],
      "default": "unidad"
    },
    "stock_min_alert": {
      "type": "decimal",
      "default": 0
    },
    "stock_item": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::stock-item.stock-item",
      "mappedBy": "producto"
    }
  }
}
