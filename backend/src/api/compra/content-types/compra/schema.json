{
  "kind": "collectionType",
  "collectionName": "compras",
  "info": {
    "singularName": "compra",
    "pluralName": "compras",
    "displayName": "Compra"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "date": {
      "type": "date",
      "required": true
    },
    "supplier": {
      "type": "string"
    },
    "total": {
      "type": "decimal",
      "default": 0
    },
    "status": {
      "type": "enumeration",
      "enum": ["pendiente", "recibida", "cancelada"],
      "default": "pendiente",
      "required": true
    },
    "notes": {
      "type": "text"
    },
    "restaurante": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::restaurante.restaurante",
      "inversedBy": "compras"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::item-compra.item-compra",
      "mappedBy": "compra"
    },
    "created_by_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
